<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.test.controller.CVDetailController"
      prefWidth="620" spacing="0"
      style="-fx-background-color: #f7f6fd;">

    <!-- ── HEADER BAR ─────────────────────────────────── -->
    <HBox style="-fx-background-color: #2d2654; -fx-padding: 16 24;"
          alignment="CENTER_LEFT" spacing="16">

        <!-- Avatar or photo -->
        <StackPane prefWidth="60" prefHeight="60"
                   style="-fx-background-color: #534AB7; -fx-background-radius: 30;">
            <ImageView fx:id="photoView" fitWidth="60" fitHeight="60"
                       preserveRatio="true"
                       style="-fx-background-radius: 30;"/>
            <Label text="CV" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </StackPane>

        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="nomCompletLabel" text=""
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="emailLabel" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #9f9bcf;"/>
            <Label fx:id="dateCandidatureLabel" text=""
                   style="-fx-font-size: 11px; -fx-text-fill: #1D9E75;"/>
        </VBox>

        <Button text="✕" onAction="#handleFermer"
                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-padding: 6 12;
                       -fx-font-size: 14px; -fx-cursor: hand;"/>
    </HBox>

    <!-- ── CV TITLE BANNER ────────────────────────────── -->
    <HBox style="-fx-background-color: #534AB7; -fx-padding: 10 24;"
          alignment="CENTER_LEFT">
        <Label fx:id="cvTitreLabel" text=""
               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <!-- ── CONTENT ────────────────────────────────────── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;
                       -fx-border-color: transparent;">
        <VBox spacing="16" style="-fx-padding: 24;">

            <!-- Formation -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-border-color: #ece9f8;
                         -fx-border-radius: 12; -fx-border-width: 0.5;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="14" arcWidth="2" arcHeight="2" fill="#534AB7"/>
                    <Label text="FORMATION"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #534AB7;"/>
                </HBox>
                <Label fx:id="formationLabel" text="" wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #444; -fx-line-spacing: 3;"/>
            </VBox>

            <!-- Expériences -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-border-color: #ece9f8;
                         -fx-border-radius: 12; -fx-border-width: 0.5;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="14" arcWidth="2" arcHeight="2" fill="#534AB7"/>
                    <Label text="EXPÉRIENCES"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #534AB7;"/>
                </HBox>
                <Label fx:id="experiencesLabel" text="" wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #444; -fx-line-spacing: 3;"/>
            </VBox>

            <!-- Compétences -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-border-color: #ece9f8;
                         -fx-border-radius: 12; -fx-border-width: 0.5;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="14" arcWidth="2" arcHeight="2" fill="#1D9E75"/>
                    <Label text="COMPÉTENCES"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;"/>
                </HBox>
                <FlowPane fx:id="competencesBadges" hgap="8" vgap="8"/>
            </VBox>

            <!-- Langues -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-padding: 20; -fx-border-color: #ece9f8;
                         -fx-border-radius: 12; -fx-border-width: 0.5;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Rectangle width="3" height="14" arcWidth="2" arcHeight="2" fill="#E49B0F"/>
                    <Label text="LANGUES"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #E49B0F;"/>
                </HBox>
                <Label fx:id="languesLabel" text="" wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #444;"/>
            </VBox>

        </VBox>
    </ScrollPane>

    <!-- ── FOOTER ─────────────────────────────────────── -->
    <HBox style="-fx-background-color: white; -fx-padding: 14 24;
                 -fx-border-color: #ece9f8; -fx-border-width: 0.5 0 0 0;"
          alignment="CENTER_RIGHT">
        <Button text="Fermer" onAction="#handleFermer"
                style="-fx-background-color: #534AB7; -fx-text-fill: white;
                       -fx-background-radius: 8; -fx-padding: 9 28;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

</VBox>
