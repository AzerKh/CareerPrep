<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.test.controller.MainController"
      prefWidth="1000" prefHeight="680">

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <VBox prefWidth="220" style="-fx-background-color: #2d2654;">

        <!-- Brand -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 22 16 18 16;
                     -fx-border-color: rgba(255,255,255,0.08);
                     -fx-border-width: 0 0 0.5 0;">
            <StackPane prefWidth="36" prefHeight="36"
                       style="-fx-background-color: #534AB7; -fx-background-radius: 10;">
                <Label text="CP"
                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </StackPane>
            <Label text="CareerPrep"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </HBox>

        <!-- User info -->
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 14 16;
                     -fx-border-color: rgba(255,255,255,0.08);
                     -fx-border-width: 0 0 0.5 0;">
            <StackPane fx:id="avatarPane" prefWidth="38" prefHeight="38"
                       style="-fx-background-color: #534AB7; -fx-background-radius: 19;">
                <Label fx:id="avatarLabel" text="?"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </StackPane>
            <VBox spacing="3">
                <Label fx:id="userNameLabel" text=""
                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <Label fx:id="userRoleLabel" text=""
                       style="-fx-font-size: 10px; -fx-padding: 2 8; -fx-background-radius: 20;"/>
            </VBox>
        </HBox>

        <!-- Nav items -->
        <VBox spacing="2" style="-fx-padding: 12 10;" VBox.vgrow="ALWAYS">

            <Button fx:id="btnProfil" text="  Profil"
                    maxWidth="Infinity" onAction="#showProfil"
                    style="-fx-background-color: #534AB7; -fx-text-fill: white;
                           -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;
                           -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"/>

            <Button fx:id="btnCV" text="  Mon CV"
                    maxWidth="Infinity" onAction="#showCV"
                    style="-fx-background-color: transparent; -fx-text-fill: #c5c2e8;
                           -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;
                           -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"/>

            <Button fx:id="btnOffres" text="  Offres d'emploi"
                    maxWidth="Infinity" onAction="#showOffres"
                    style="-fx-background-color: transparent; -fx-text-fill: #c5c2e8;
                           -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;
                           -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"/>

            <Button fx:id="btnIA" text="  Assistant IA"
                    maxWidth="Infinity" onAction="#showIA"
                    style="-fx-background-color: transparent; -fx-text-fill: #c5c2e8;
                           -fx-background-radius: 8; -fx-padding: 10 14; -fx-font-size: 13px;
                           -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"/>
        </VBox>

        <!-- Logout -->
        <VBox style="-fx-padding: 12 10 20 10;
                     -fx-border-color: rgba(255,255,255,0.08);
                     -fx-border-width: 0.5 0 0 0;">
            <Button text="  Se déconnecter" maxWidth="Infinity"
                    onAction="#handleDeconnexion"
                    style="-fx-background-color: transparent; -fx-text-fill: #ff6b6b;
                           -fx-border-color: rgba(255,107,107,0.35); -fx-border-radius: 8;
                           -fx-background-radius: 8; -fx-padding: 9 14; -fx-font-size: 13px;
                           -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"/>
        </VBox>
    </VBox>

    <!-- ══════════════ CONTENT ══════════════ -->
    <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS"
               style="-fx-background-color: #f7f6fd; -fx-padding: 28;"/>

</HBox>
