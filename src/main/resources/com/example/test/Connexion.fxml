<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.test.controller.ConnexionController"
      prefWidth="860" prefHeight="520">

    <!-- ── LEFT PANEL ───────────────────────────────────────── -->
    <VBox prefWidth="360" alignment="CENTER" spacing="0"
          style="-fx-background-color: #2d2654; -fx-padding: 40 32;">

        <!-- Logo -->
        <StackPane prefWidth="72" prefHeight="72"
                   style="-fx-background-color: #534AB7; -fx-background-radius: 36;">

            <SVGPath content="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6H6zm0 2h7v5h5v11H6V4zm2 8v2h8v-2H8zm0 4v2h5v-2H8z"
                     style="-fx-fill: white; -fx-scale-x: 1.2; -fx-scale-y: 1.2;"/>

        </StackPane>

        <Region prefHeight="16"/>

        <Text text="CareerPrep"
              style="-fx-fill: white; -fx-font-size: 26; -fx-font-weight: bold;"/>

        <Region prefHeight="6"/>

        <Text text="Plateforme intelligente de préparation à l'emploi"
              style="-fx-fill: #9f9bcf; -fx-font-size: 12;" textAlignment="CENTER"
              wrappingWidth="260"/>

        <Region prefHeight="32"/>

        <!-- Feature cards -->
        <VBox spacing="12" maxWidth="280">

            <!-- CV -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.07);
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 14;">
                <StackPane prefWidth="36" prefHeight="36"
                           style="-fx-background-color: #534AB7; -fx-background-radius: 8;">
                    <SVGPath content="M6 2a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6H6zm0 2h7v5h5v11H6V4zm2 8v2h8v-2H8zm0 4v2h5v-2H8z"
                             style="-fx-fill: white; -fx-scale-x: 0.7; -fx-scale-y: 0.7;"/>
                </StackPane>
                <VBox spacing="2">
                    <Text text="CV Intelligent"
                          style="-fx-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Text text="Créez et exportez votre CV en PDF"
                          style="-fx-fill: #c5c2e8; -fx-font-size: 11;"/>
                </VBox>
            </HBox>

            <!-- IA -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.07);
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 14;">
                <StackPane prefWidth="36" prefHeight="36"
                           style="-fx-background-color: #534AB7; -fx-background-radius: 8;">
                    <SVGPath content="M12 2a9 9 0 0 1 9 9c0 3.6-2.1 6.7-5.2 8.2L15 21H9l-.8-1.8A9 9 0 0 1 3 11a9 9 0 0 1 9-9m0 2a7 7 0 0 0-7 7 7 7 0 0 0 4.6 6.6L10 19h4l.4-1.4A7 7 0 0 0 19 11a7 7 0 0 0-7-7m-1 3h2v2h-2V7m0 4h2v6h-2v-6z"
                             style="-fx-fill: white; -fx-scale-x: 0.7; -fx-scale-y: 0.7;"/>
                </StackPane>
                <VBox spacing="2">
                    <Text text="Assistant IA"
                          style="-fx-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Text text="Powered by Google Gemini 2.5"
                          style="-fx-fill: #c5c2e8; -fx-font-size: 11;"/>
                </VBox>
            </HBox>

            <!-- Offres -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.07);
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 14;">
                <StackPane prefWidth="36" prefHeight="36"
                           style="-fx-background-color: #1D9E75; -fx-background-radius: 8;">
                    <SVGPath content="M20 6h-2.18c.07-.44.18-.88.18-1a3 3 0 0 0-6 0c0 .12.11.56.18 1H10C8.9 6 8 6.9 8 8v12c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-7-1a1 1 0 0 1 2 0c0 .5-.5 1-1 1s-1-.5-1-1zm-1 14l-3-3 1.41-1.41L12 17.17l4.59-4.58L18 14l-6 6z"
                             style="-fx-fill: white; -fx-scale-x: 0.7; -fx-scale-y: 0.7;"/>
                </StackPane>
                <VBox spacing="2">
                    <Text text="Offres d'emploi"
                          style="-fx-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Text text="Postulez avec votre CV en un clic"
                          style="-fx-fill: #c5c2e8; -fx-font-size: 11;"/>
                </VBox>
            </HBox>

        </VBox>
    </VBox>

    <!-- ── RIGHT PANEL ──────────────────────────────────────── -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
          style="-fx-background-color: #f5f4fc; -fx-padding: 48 44;">

        <VBox maxWidth="340" spacing="0">

            <Text text="Bon retour !"
                  style="-fx-fill: #2c2c2c; -fx-font-size: 22; -fx-font-weight: bold;"/>

            <Region prefHeight="4"/>

            <Text text="Connectez-vous à votre compte"
                  style="-fx-fill: #888; -fx-font-size: 13;"/>

            <Region prefHeight="28"/>

            <Text text="Adresse email"
                  style="-fx-fill: #555; -fx-font-size: 11; -fx-font-weight: bold;"/>
            <Region prefHeight="5"/>
            <TextField fx:id="emailField" promptText="exemple@email.com" maxWidth="Infinity"
                       style="-fx-background-color: white; -fx-border-color: #ddd;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 14; -fx-font-size: 14px;"/>

            <Region prefHeight="14"/>

            <Text text="Mot de passe"
                  style="-fx-fill: #555; -fx-font-size: 11; -fx-font-weight: bold;"/>
            <Region prefHeight="5"/>
            <PasswordField fx:id="passwordField" promptText="••••••••" maxWidth="Infinity"
                           style="-fx-background-color: white; -fx-border-color: #ddd;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 10 14; -fx-font-size: 14px;"/>

            <Region prefHeight="8"/>

            <Label fx:id="errorLabel" text="" wrapText="true"
                   style="-fx-text-fill: #c0392b; -fx-font-size: 12px;"/>

            <Region prefHeight="12"/>

            <Button fx:id="connexionBtn" text="Se connecter"
                    onAction="#handleConnexion" maxWidth="Infinity"
                    style="-fx-background-color: #534AB7; -fx-text-fill: white;
                           -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-padding: 11 0; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Region prefHeight="24"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Pas encore de compte ?"
                       style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
                <Hyperlink text="S'inscrire" onAction="#goToInscription"
                           style="-fx-text-fill: #534AB7; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-border-color: transparent;"/>
            </HBox>

        </VBox>
    </VBox>

</HBox>
